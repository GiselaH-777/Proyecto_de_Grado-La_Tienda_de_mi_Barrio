/* To learn more about TypeScript configuration: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": false,
    "types": []
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/test.ts",
    "src/main.test.ts"
  ]
}
